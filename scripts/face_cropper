"""
Face-cropping pipeline for FER datasets (hasnt been applied to any current dataset yet but keep first just in case).

Key design choices vs. a naive version:
- FaceMesh is created ONCE and reused across the dataset (fast).
- Undetected faces are SKIPPED and LOGGED, never replaced with a full-image
  resize (which would inject mislabeled samples into training).
- Square crop is guaranteed via constant-border padding AFTER cropping, so
  the face is never warped by an aspect-ratio-distorting resize.
- Extra top margin compensates for FaceMesh excluding the forehead/hairline.
- Batch mode walks a directory tree and mirrors the class-folder structure.
"""
'''
import csv
import logging
from pathlib import Path

import cv2
import mediapipe as mp

logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
log = logging.getLogger("face_cropper")


class FaceCropper:
    def __init__(
        self,
        out_size=300,          # EfficientNet-B3 native input
        padding_ratio=0.15,    # symmetric pad as fraction of face size
        top_extra_ratio=0.25,  # extra pad on top to recover forehead
        min_detection_confidence=0.5,
        pad_color=(0, 0, 0),   # border color for letterboxing (BGR)
    ):
        self.out_size = out_size
        self.padding_ratio = padding_ratio
        self.top_extra_ratio = top_extra_ratio
        self.pad_color = pad_color
        self.face_mesh = mp.solutions.face_mesh.FaceMesh(
            static_image_mode=True,
            max_num_faces=1,
            refine_landmarks=True,
            min_detection_confidence=min_detection_confidence,
        )

    def crop(self, image_path):
        """Return a square out_size x out_size BGR crop, or None on failure."""
        image = cv2.imread(str(image_path))
        if image is None:
            log.warning("unreadable: %s", image_path)
            return None

        h, w = image.shape[:2]
        results = self.face_mesh.process(cv2.cvtColor(image, cv2.COLOR_BGR2RGB))
        if not results.multi_face_landmarks:
            log.warning("no face: %s", image_path)
            return None

        lms = results.multi_face_landmarks[0].landmark
        xs = [lm.x * w for lm in lms]
        ys = [lm.y * h for lm in lms]
        x_min, x_max = min(xs), max(xs)
        y_min, y_max = min(ys), max(ys)

        fw, fh = x_max - x_min, y_max - y_min
        pad_w = fw * self.padding_ratio
        pad_h = fh * self.padding_ratio

        # Desired (possibly off-image) box. Asymmetric top pad recovers the
        # forehead the mesh omits.
        x0 = x_min - pad_w
        x1 = x_max + pad_w
        y0 = y_min - pad_h - fh * self.top_extra_ratio
        y1 = y_max + pad_h

        # Force the DESIRED box square first, around its own center, before any
        # clipping. Using one integer side length (not independent rounding per
        # edge) guarantees an exactly square result.
        bw, bh = x1 - x0, y1 - y0
        side = int(round(max(bw, bh)))
        cx, cy = (x0 + x1) / 2, (y0 + y1) / 2
        box_x0 = int(round(cx - side / 2))
        box_y0 = int(round(cy - side / 2))
        box_x1 = box_x0 + side
        box_y1 = box_y0 + side

        # Clip to the image; whatever the edge denies becomes a constant border,
        # so the box stays square and the face is never warped.
        cx0, cy0 = max(0, box_x0), max(0, box_y0)
        cx1, cy1 = min(w, box_x1), min(h, box_y1)
        if cx1 <= cx0 or cy1 <= cy0:
            log.warning("degenerate box: %s", image_path)
            return None

        crop = image[cy0:cy1, cx0:cx1]
        top    = cy0 - box_y0
        bottom = box_y1 - cy1
        left   = cx0 - box_x0
        right  = box_x1 - cx1

        crop = cv2.copyMakeBorder(
            crop, top, bottom, left, right,
            cv2.BORDER_CONSTANT, value=self.pad_color,
        )
        return cv2.resize(crop, (self.out_size, self.out_size),
                          interpolation=cv2.INTER_AREA)

    def process_tree(self, in_dir, out_dir, exts=(".jpg", ".jpeg", ".png", ".bmp")):
        """Mirror in_dir's structure into out_dir; log every failure to CSV."""
        in_dir, out_dir = Path(in_dir), Path(out_dir)
        out_dir.mkdir(parents=True, exist_ok=True)
        ok = skipped = 0
        fails = []

        files = [p for p in in_dir.rglob("*") if p.suffix.lower() in exts]
        log.info("found %d images under %s", len(files), in_dir)

        for p in files:
            face = self.crop(p)
            rel = p.relative_to(in_dir)
            if face is None:
                skipped += 1
                fails.append(str(rel))
                continue
            dst = out_dir / rel
            dst.parent.mkdir(parents=True, exist_ok=True)
            cv2.imwrite(str(dst), face)
            ok += 1

        if fails:
            report = out_dir / "_failures.csv"
            with open(report, "w", newline="") as f:
                w = csv.writer(f)
                w.writerow(["relative_path"])
                for r in fails:
                    w.writerow([r])
            log.info("failures logged to %s", report)

        log.info("done: %d ok, %d skipped", ok, skipped)
        return ok, skipped

    def close(self):
        self.face_mesh.close()


# ============================================================
#  EDIT THESE, THEN JUST RUN THE FILE:  python face_cropper.py
# ============================================================
INPUT_DIR  = "C:/Users/Acer/Documents/AffectNet/test/3"            # folder of images (subfolders OK)
OUTPUT_DIR = "C:/Users/Acer/Documents/AffectNet/test/cropped_3"  # cropped faces written here

OUT_SIZE        = 300    # 300 = EfficientNet-B3 input
PADDING_RATIO   = 0.15   # symmetric pad around the face
TOP_EXTRA_RATIO = 0.25   # extra pad on top to recover the forehead
MIN_CONFIDENCE  = 0.5    # face-detection threshold
# ============================================================


def main():
    cropper = FaceCropper(
        out_size=OUT_SIZE,
        padding_ratio=PADDING_RATIO,
        top_extra_ratio=TOP_EXTRA_RATIO,
        min_detection_confidence=MIN_CONFIDENCE,
    )
    try:
        cropper.process_tree(INPUT_DIR, OUTPUT_DIR)
    finally:
        cropper.close()


if __name__ == "__main__":
    main()
'''