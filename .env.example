# Spotify Developer App credentials
SPOTIFY_CLIENT_ID=client_id
SPOTIFY_CLIENT_SECRET=client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# MySQL database (fill in during database setup phase)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=emotion_music
DB_USER=db_user
DB_PASSWORD=db_password

# Local paths (RAF-DB stays on your machine, never committed to the repo)
RAF_DB_DIR=C:/path/to/raf-db/DATASET
MODEL_PATH=models/fer_model.keras
